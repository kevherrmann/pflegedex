:80 {
    root * /var/www/html/public
    encode zstd gzip
    php_fastcgi app:9000
    file_server

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        # TLS terminiert der ngrok-Tunnel; Browser kuenftig nur noch via https.
        Strict-Transport-Security "max-age=31536000"
        # Clickjacking-Schutz auch modern (frame-ancestors). Volle CSP folgt in Phase 2,
        # nachdem inline-Skripte (Ziggy/Inertia) im Browser geprueft sind.
        Content-Security-Policy "frame-ancestors 'none'"
        # Server-Version nicht preisgeben.
        -Server
    }
}
