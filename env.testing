APP_NAME=Pflegedex
APP_ENV=testing
APP_KEY=base64:1HBv7uCvCKXnFqDiyJtDXVNZuALW3TIr4VtHbkVFeXU=
APP_DEBUG=true
APP_TIMEZONE=Europe/Berlin
APP_URL=http://localhost:8080
APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=pflegedex
DB_USERNAME=pflegedex
DB_PASSWORD=pflegedex

# Wichtig: alles in-memory damit Tests deterministisch laufen
# und keine Redis/DB-Abhaengigkeit fuer Sessions/Cache
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=array
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MAIL_MAILER=array

# Redis-Config bleibt fuer den Fall dass mal etwas explizit Redis nutzt;
# aber die obige SESSION/CACHE/QUEUE-Konfig leitet weg davon.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
